# ============================================================================
# Sqemes — environment reference (SQEM-056)
# ============================================================================
# This file documents EVERY environment variable the app uses. Two homes:
#   • VITE_* vars  → the FRONTEND build. Copy this file to `.env.local` and fill them.
#   • everything else → SUPABASE EDGE-FUNCTION secrets, set with:
#                       `supabase secrets set NAME=value --project-ref <ref>`
#     (NOT in .env.local — the frontend never sees them.)
#
# Never commit `.env.local`, `.env.staging`, or `.env.production`.
# For an isolated local stack, `npm run local:fresh` writes local Supabase values here.
# See SELF_HOSTING.md for the full self-host walkthrough.


# ---------------------------------------------------------------------------
# FRONTEND (.env.local) — required
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_<your-publishable-key>

# ---------------------------------------------------------------------------
# FRONTEND (.env.local) — self-host + optional
# ---------------------------------------------------------------------------
# Self-host (open core): 'true' disables the subscription paywall in the UI. Pair with the
# server-side SELF_HOSTED secret below. Cloud leaves this unset.
VITE_SELF_HOSTED=

# Error monitoring (Cloud-only). Unset → Sentry compiles out; structured console logging remains.
VITE_SENTRY_DSN=


# ===========================================================================
# SUPABASE EDGE-FUNCTION SECRETS  (supabase secrets set …)
# ===========================================================================

# --- Auto-injected by Supabase — do NOT set manually ---
#   SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY

# --- Core (required) ---
# AES-GCM key that encrypts BYOK provider keys at rest (workspace_api_keys.encrypted_key).
API_KEY_ENCRYPTION_KEY=<32-byte-random-hex>
# Frontend origin used for OAuth redirects + email links (e.g. https://app.yourdomain.com).
APP_URL=https://app.yourdomain.com

# --- Self-host (open core) ---
# 'true' bypasses the subscription model server-side (paywall in execute-step/chat-message/mcp-server).
SELF_HOSTED=true

# --- Cloud-only — absent means the feature is simply OFF (no crash) ---
# Billing (Stripe). Absent → checkout/portal/webhook inert + billing UI hidden. SELF_HOSTED bypasses the paywall.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SOLO_MONTHLY_PRICE_ID=
STRIPE_SOLO_YEARLY_PRICE_ID=
STRIPE_TEAM_MONTHLY_PRICE_ID=
STRIPE_TEAM_YEARLY_PRICE_ID=
STRIPE_BUSINESS_MONTHLY_PRICE_ID=
STRIPE_BUSINESS_YEARLY_PRICE_ID=
# Platform "Sqemes AI" funded model. Absent → no funded/keyless AI; users add their own BYOK keys.
MISTRAL_API_KEY=
# Transactional email (team invites). Absent → invites still created; the UI shows a copyable invite link (SQEM-112).
RESEND_API_KEY=
RESEND_FROM_EMAIL=sqemes <noreply@yourdomain.com>
# Custom domain for MCP/OAuth advertising. Absent → the Supabase project URL is advertised.
PUBLIC_API_URL=
# Abandoned-workspace cleanup cron. Absent → the cleanup function is disabled (self-host can skip it).
CRON_SECRET=

# --- Optional config (sensible defaults) ---
RATE_LIMIT_RPM=60                       # per-workspace API rate limit
ALLOWED_ORIGINS=https://app.yourdomain.com   # CORS allow-list (comma-separated); dev allows all
SITE_URL=https://app.yourdomain.com     # fallback origin for invite links when the Origin header is absent
